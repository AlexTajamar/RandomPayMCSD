@using RandomPayMCSD.Models
@using RandomPayMCSD.Extensions
@model List<Actividad>
@{
    Usuario user = Context.Session.getObject<Usuario>("USUARIO_LOGUEADO");
}

<style>
    /* Estilos modernos */
    .welcome-card {
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border-left: 8px solid #2563eb;
    }

    .btn-brand-action {
        background: linear-gradient(145deg, #2563eb, #1d4ed8);
        color: white;
        border-radius: 16px;
        padding: 1.75rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: all 0.3s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        height: 100%;
        text-decoration: none;
    }

        .btn-brand-action:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px rgba(0,0,0,0.15);
            color: white; /* Para que el texto no cambie de color al pasar el ratón */
        }

        .btn-brand-action i {
            font-size: 2.5rem;
            margin-bottom: 0.75rem;
        }

    .activity-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

        .activity-card:hover {
            border-color: #2563eb;
            transform: scale(1.02);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        }

    .activity-icon {
        width: 56px;
        height: 56px;
        background: #eff6ff;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2563eb;
        font-size: 1.8rem;
        margin-right: 1rem;
    }

    .badge-soft-primary {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 0.4rem 1rem;
        border-radius: 30px;
        font-size: 0.85rem;
    }
</style>

@if (user != null)
{
    <div class="container mt-5 mb-5">
        <div class="welcome-card mb-5">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-soft-primary p-3 me-4" style="width: 70px; height: 70px;">
                    <i class="fa-solid fa-hand-holding-dollar fa-2x" style="color: #2563eb;"></i>
                </div>
                <div>
                    <h1 style="color: #2563eb; font-weight: 800;">¡Bienvenido, @user.NOMBRE!</h1>
                    <p class="fs-5 text-muted mb-0">Tu rol: <span class="badge-soft-primary ms-2">@user.ROL</span></p>
                </div>
            </div>
        </div>

        <h4 class="mb-4 fw-bold text-secondary">¿Qué quieres hacer hoy?</h4>
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <a asp-controller="Actividades" asp-action="Crear" class="btn-brand-action">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Nueva ListPay</span>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Statics" asp-action="RandomPay" class="btn-brand-action" style="background: linear-gradient(145deg, #8b5cf6, #6d28d9);">
                    <i class="fa-solid fa-dice"></i>
                    <span>Nuevo RandomPay</span>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Statics" asp-action="Divisas" class="btn-brand-action" style="background: linear-gradient(145deg, #10b981, #059669);">
                    <i class="fa-solid fa-arrow-right-arrow-left"></i>
                    <span>DivisaChange</span>
                </a>
            </div>
        </div>

        <h4 class="mb-4 fw-bold text-secondary">Mis ListPays</h4>
        <div class="row g-3">
            @if (Model != null && Model.Any())
            {
                @foreach (var actividad in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <a asp-controller="Actividades" asp-action="Detalle" asp-route-id="@actividad.IDACTIVIDAD" class="activity-card">
                            <div class="activity-icon">
                                <i class="fa-solid fa-receipt"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1">@actividad.NOMBREACTIVIDAD</h6>
                                <small class="text-muted"><i class="fa-regular fa-money-bill-1 me-1"></i>@actividad.MONEDAPRINCIPAL</small>
                            </div>
                            <i class="fa-solid fa-chevron-right text-muted"></i>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-light border text-center p-5 rounded-4">
                        <i class="fa-regular fa-face-smile fs-1 text-muted mb-3"></i>
                        <p class="mb-0 text-muted fs-5">Aún no participas en ninguna actividad.</p>
                        <a asp-controller="Actividades" asp-action="Crear" class="btn btn-outline-primary rounded-pill mt-3 px-4" style="border-color: #2563eb; color: #2563eb;">Crear primera actividad</a>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="container mt-5 text-center">
        <div class="p-5 bg-white rounded-4 shadow-sm">
            <h2 class="text-danger mb-4"><i class="fa-solid fa-lock me-2"></i>No has iniciado sesión</h2>
            <a asp-controller="RandomLogIn" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3" style="background: #2563eb;">Ir al Login</a>
        </div>
    </div>
}