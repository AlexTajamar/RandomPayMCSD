@model List<RandomPayMCSD.Models.Divisa>
@{
    ViewData["Title"] = "DivisaChange Pro";
    double resultado = ViewBag.Resultado ?? 0;
    string importeValor = ViewBag.Importe != null ? ViewBag.Importe.ToString() : "";
}

<div class="bg-dashboard pt-3">
    <div class="container mb-5 d-flex justify-content-center">
        <div class="clean-card text-center" style="max-width: 550px; width: 100%;">
            <div class="p-3 bg-success bg-opacity-10 text-success rounded-circle d-inline-block mb-3">
                <i class="fa-solid fa-money-bill-transfer fa-3x"></i>
            </div>

            <h2 class="fw-bold text-dark mb-1">DivisaChange</h2>
            <p class="text-muted mb-4 small">Conversión de divisas en tiempo real</p>

            <form asp-action="Divisas" method="post">
                <div class="mb-4 text-start">
                    <label class="form-label fw-bold text-muted small">CANTIDAD A CONVERTIR</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px; border: 2px solid #e5e7eb;">
                            <i class="fa-solid fa-coins text-success"></i>
                        </span>
                        <input type="text" name="importeString" class="form-control custom-input border-start-0"
                               style="border-radius: 0 12px 12px 0;" placeholder="0.00" value="@importeValor" required autocomplete="off">
                    </div>
                </div>

                <div class="row g-3 mb-4 text-start">
                    <div class="col-6">
                        <label class="form-label fw-bold text-muted small">DE:</label>
                        <select name="origen" class="form-select custom-input">
                            @foreach (var d in Model)
                            {
                                if (d.Codigo == ViewBag.Origen)
                                {
                                    <option value="@d.Codigo" selected="selected">@d.Codigo</option>
                                }
                                else
                                {
                                    <option value="@d.Codigo">@d.Codigo</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold text-muted small">A:</label>
                        <select name="destino" class="form-select custom-input">
                            @foreach (var d in Model)
                            {
                                if (d.Codigo == ViewBag.Destino)
                                {
                                    <option value="@d.Codigo" selected="selected">@d.Codigo</option>
                                }
                                else
                                {
                                    <option value="@d.Codigo">@d.Codigo</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <button type="submit" class="btn-primary-custom w-100 py-3 text-uppercase" style="background-color: #10b981;">
                    Convertir Dinero <i class="fa-solid fa-chevron-right ms-2 small"></i>
                </button>
            </form>

            @if (resultado > 0)
            {
                <div class="mt-4 p-4 rounded-4" style="background-color: #ecfdf5; border: 2px solid #10b981;">
                    <p class="text-uppercase small fw-bold text-muted mb-1">Tienes aproximadamente:</p>
                    <h3 class="fw-bold m-0" style="color: #065f46; font-size: 2.5rem;">@resultado.ToString("F2")</h3>
                    <span class="fw-bold" style="color: #059669; font-size: 1.1rem;">@ViewBag.Destino</span>
                </div>
            }

            <div class="mt-4">
                <a asp-controller="Statics" asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                    <i class="fa-solid fa-arrow-left me-1"></i> VOLVER AL PANEL
                </a>
            </div>
        </div>
    </div>
</div>