@model List<RandomPayMCSD.Models.Actividad>
@{
    ViewData["Title"] = "Inicio";
    var user = Context.Session.getObject<RandomPayMCSD.Models.Usuario>("USUARIO_LOGUEADO");

    // Calculamos el total de los gastos de TODAS las actividades
    decimal totalGastosAcumulados = 0;
    if (Model != null)
    {
        foreach (var actividad in Model)
        {
            if (actividad.Gastos != null)
            {
                totalGastosAcumulados += actividad.Gastos.Sum(g => g.IMPORTE);
            }
        }
    }
}

<style>
    /* NUEVA TARJETA DE RESUMEN DE GASTOS */
    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        margin-top: 1rem;
    }

    @@media (max-width: 768px) {
        .summary-card {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }
    }

    /* Diseño de las Action Cards */
    .action-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        color: white;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-align: center;
        height: 100%;
    }

        .action-card:hover {
            transform: translateY(-5px);
            color: white;
            box-shadow: 0 12px 20px rgba(0,0,0,0.15);
        }

    .icon-circle {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .bg-blue {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
    }

    .bg-purple {
        background: linear-gradient(135deg, #7c3aed, #8b5cf6);
    }

    .bg-green {
        background: linear-gradient(135deg, #10b981, #14b8a6);
    }

    .bg-orange {
        background: linear-gradient(135deg, #f59e0b, #d97706);
    }

    .activity-card {
        background: white;
        border: 1px solid #f1f5f9;
        border-radius: 18px;
        padding: 1.25rem;
        transition: all 0.2s;
        position: relative;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

        .activity-card:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border-color: #e2e8f0;
        }

    .activity-link {
        text-decoration: none;
        color: inherit;
    }

    .btn-delete-act {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
        color: #64748b;
        border: none;
        transition: all 0.2s;
        z-index: 10;
        font-size: 0.75rem;
    }

        .btn-delete-act:hover {
            background: #fee2e2;
            color: #ef4444;
        }
</style>

<div class="bg-dashboard pt-3">
    <div class="container mb-5 max-w-6xl">

    <div class="summary-card">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 65px; height: 65px;">
                <i class="fa-solid fa-wallet fa-2x"></i>
            </div>
            <div>
                <span class="text-muted fw-bold small text-uppercase">Histórico Global</span>
                <h5 class="fw-bold mb-0 text-dark">Total movido en tus grupos</h5>
            </div>
        </div>
        <div class="text-md-end mt-3 mt-md-0">
            <h2 class="mb-0 text-primary" style="font-weight: 900; font-size: 2.5rem; line-height: 1;">
                @totalGastosAcumulados.ToString("F2") <span class="fs-5 text-muted fw-bold">€</span>
            </h2>
        </div>
    </div>

    <h6 class="fw-bold text-dark mb-3">¿Qué quieres hacer hoy?</h6>

    <div class="row row-cols-2 row-cols-md-4 g-3 mb-5">
        <div class="col">
            <a asp-controller="Actividades" asp-action="Crear" class="action-card bg-blue shadow-sm">
                <div class="icon-circle"><i class="fa-solid fa-plus"></i></div>
                <div class="fw-bold small">Nueva ListPay</div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Actividades" asp-action="Unirse" class="action-card bg-orange shadow-sm">
                <div class="icon-circle"><i class="fa-solid fa-key"></i></div>
                <div class="fw-bold small">Unirse con Código</div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Statics" asp-action="RandomPay" class="action-card bg-purple shadow-sm">
                <div class="icon-circle"><i class="fa-solid fa-dice"></i></div>
                <div class="fw-bold small">Nuevo RandomPay</div>
            </a>
        </div>
        <div class="col">
            <a asp-controller="Statics" asp-action="Divisas" class="action-card bg-green shadow-sm">
                <div class="icon-circle"><i class="fa-solid fa-money-bill-transfer"></i></div>
                <div class="fw-bold small">DivisaChange</div>
            </a>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-dark mb-0">Mis ListPays</h5>
        <span class="badge bg-light text-dark border">@Model?.Count() Actividades</span>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var actividad in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="activity-card h-100">

                        <form asp-controller="Actividades" asp-action="AbandonarActividad" method="post"
                              onsubmit="return confirm('¿Quieres quitar esta actividad de tu panel? Podrás volver a entrar con el código.');">
                            <input type="hidden" name="idActividad" value="@actividad.IDACTIVIDAD" />
                            <button type="submit" class="btn-delete-act" title="Quitar de mi lista">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </form>

                        <a asp-controller="Actividades" asp-action="Detalle" asp-route-id="@actividad.IDACTIVIDAD" class="activity-link">
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(actividad.IMAGEN) && actividad.IMAGEN.StartsWith("/"))
                                {
                                    <img src="@actividad.IMAGEN" class="rounded-circle me-3 shadow-sm" style="width: 52px; height: 52px; object-fit: cover; border: 2px solid #f8fafc;" alt="Portada">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle me-3 fs-4" style="width: 52px; height: 52px;">
                                        @(string.IsNullOrEmpty(actividad.IMAGEN) ? "✈️" : actividad.IMAGEN)
                                    </div>
                                }

                                <div class="overflow-hidden">
                                    <h6 class="fw-bold mb-0 text-dark text-truncate">@actividad.NOMBREACTIVIDAD</h6>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <span class="badge bg-light text-muted border fw-normal" style="font-size: 0.7rem;">@actividad.MONEDAPRINCIPAL</span>
                                        <span class="text-primary x-small fw-bold" style="font-size: 0.75rem;">Ver detalles <i class="fa-solid fa-chevron-right ms-1"></i></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5 bg-light rounded-4 border border-dashed">
                    <i class="fa-solid fa-folder-open fa-3x text-muted mb-3 opacity-25"></i>
                    <h6 class="fw-bold text-dark">No tienes ninguna actividad</h6>
                    <p class="text-muted mb-0 small">Crea una nueva ListPay o únete a una existente.</p>
                </div>
            </div>
        }
    </div>

    </div>
</div>