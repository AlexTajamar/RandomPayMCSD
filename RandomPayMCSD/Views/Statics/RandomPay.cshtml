@model List<string>
@{
    ViewData["Title"] = "RandomPay - La Ruleta";
    string ganador = ViewBag.Ganador as string;
}

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="clean-card text-center" style="max-width: 600px; width: 100%; border-top: 6px solid #8b5cf6;">
        <div class="p-3 mb-3 d-inline-block rounded-circle" style="background-color: #f3e8ff;">
            <i class="fa-solid fa-dice fa-3x" style="color: #8b5cf6;"></i>
        </div>

        <h2 class="fw-bold text-dark mb-2">Sorteo RandomPay</h2>
        <p class="text-muted mb-4">Añade a los amigos y deja que el azar decida quién invita hoy.</p>

        <form asp-action="AddNombreRandom" asp-controller="Statics" method="post" class="mb-4">
            <div class="input-group">
                <input type="text" name="nombre" class="form-control custom-input" placeholder="Ej: Álex..." required autofocus autocomplete="off" style="border-radius: 12px 0 0 12px;">
                <button type="submit" class="btn btn-dark px-4" style="border-radius: 0 12px 12px 0;">
                    <i class="fa-solid fa-plus"></i> Añadir
                </button>
            </div>
        </form>

        <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
            @if (Model != null && Model.Any())
            {
                foreach (var nombre in Model)
                {
                    <div class="badge bg-light text-dark border p-2 px-3 rounded-pill d-flex align-items-center">
                        <span class="fw-semibold fs-6">@nombre</span>
                        <form asp-action="RemoveNombreRandom" asp-controller="Statics" method="post" class="m-0 p-0 ms-2">
                            <input type="hidden" name="nombre" value="@nombre" />
                            <button type="submit" class="btn btn-link text-danger p-0 m-0 border-0 text-decoration-none">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </form>
                    </div>
                }
            }
            else
            {
                <span class="text-muted small">No hay participantes todavía. Añade a alguien arriba.</span>
            }
        </div>

        <div class="p-4 rounded-4 mb-4 border" style="background-color: #f8fafc;">
            @if (!string.IsNullOrEmpty(ganador))
            {
                <div class="fw-bold" style="font-size: 3.5rem; color: #ef4444; word-break: break-all;">@ganador</div>
                <div class="badge bg-danger mt-2">¡LE TOCA PAGAR!</div>
            }
            else
            {
                <div class="fw-bold text-muted" style="font-size: 3.5rem;">?</div>
            }
        </div>

        @if (Model != null && Model.Count > 1)
        {
            <form asp-action="SortearRandom" asp-controller="Statics" method="post">
                <button type="submit" class="btn-primary-custom w-100 py-3 fs-5" style="background-color: #8b5cf6;">
                    <i class="fa-solid fa-rotate me-2"></i> ¡Girar la Ruleta!
                </button>
            </form>
        }
        else
        {
            <button class="btn btn-secondary w-100 py-3 fs-5 rounded-3 fw-bold" disabled>
                <i class="fa-solid fa-rotate me-2"></i> Mínimo 2 personas
            </button>
        }

        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
            <a asp-controller="Statics" asp-action="Index" class="text-decoration-none text-muted fw-bold small">
                <i class="fa-solid fa-arrow-left me-1"></i> Volver al inicio
            </a>
            @if (Model != null && Model.Any())
            {
                <form asp-action="ResetRandom" asp-controller="Statics" method="post">
                    <button type="submit" class="btn btn-link text-danger text-decoration-none p-0 fw-bold small">
                        <i class="fa-solid fa-trash-can me-1"></i> Limpiar lista
                    </button>
                </form>
            }
        </div>
    </div>
</div>