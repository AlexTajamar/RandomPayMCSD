@model List<string>
@{
    ViewData["Title"] = "RandomPay - El Sorteo";
    string ganador = ViewBag.Ganador as string;
}

<style>
    .bg-draw {
        background: #f8fafc;
        min-height: 90vh;
        padding-top: 50px;
    }

    .draw-machine {
        background: white;
        border-radius: 35px;
        box-shadow: 0 25px 50px -12px rgba(139, 92, 246, 0.15);
        padding: 3rem 2rem;
        max-width: 600px;
        margin: 0 auto;
        border: 1px solid #f1f5f9;
        position: relative;
        overflow: hidden;
    }

        .draw-machine::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 10px;
            background: linear-gradient(90deg, #8b5cf6, #d8b4fe);
        }

    .slot-display {
        background: #1e293b;
        border-radius: 20px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 2rem 0;
        box-shadow: inset 0 8px 15px rgba(0,0,0,0.5);
        border: 4px solid #334155;
        position: relative;
    }

        .slot-display::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(rgba(0,0,0,0.2) 0%, transparent 20%, transparent 80%, rgba(0,0,0,0.2) 100%);
            pointer-events: none;
        }

    .nombre-ganador {
        font-size: 3.2rem;
        font-weight: 900;
        color: #f8fafc;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
    }

    .winner-glow {
        color: #10b981;
        text-shadow: 0 0 30px rgba(16, 185, 129, 0.6);
        animation: pulse-winner 1.5s infinite;
    }

    @@keyframes pulse-winner {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    .friend-badge {
        background: #f1f5f9;
        color: #475569;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
    }

        .friend-badge:hover {
            background: #fee2e2;
            color: #ef4444;
            border-color: #fecaca;
        }

    .btn-remove {
        border: none;
        background: #cbd5e1;
        color: white;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        cursor: pointer;
    }

    .friend-badge:hover .btn-remove {
        background: #ef4444;
    }

    .input-draw {
        border: 2px solid #e2e8f0;
        border-radius: 15px !important;
        padding: 1rem 1.5rem;
        font-weight: 600;
    }

        .input-draw:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
        }

    .btn-spin-master {
        background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 1.2rem;
        font-size: 1.4rem;
        font-weight: 800;
        width: 100%;
        box-shadow: 0 10px 20px -5px rgba(109, 40, 217, 0.4);
        transition: all 0.3s;
    }

        .btn-spin-master:hover:not(:disabled) {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(109, 40, 217, 0.5);
        }

        .btn-spin-master:active {
            transform: translateY(1px);
        }

        .btn-spin-master:disabled {
            background: #cbd5e1;
            box-shadow: none;
        }
</style>

<div class="bg-draw">
    <div class="container">
        <div class="draw-machine text-center">
            <div class="mb-4">
                <div class="d-inline-block p-3 rounded-circle bg-light mb-3">
                    <i class="fa-solid fa-dice fa-3x" style="color: #8b5cf6;"></i>
                </div>
                <h2 class="fw-extrabold" style="color: #1e293b;">RandomPay</h2>
                <p class="text-muted">Añade participantes y que el azar decida.</p>
            </div>

            <div class="mb-5">
                <form asp-action="AddNombreRandom" asp-controller="Statics" method="post">
                    <div class="input-group">
                        <input type="text" name="nombre" class="form-control input-draw" placeholder="Nombre del amigo..." required autofocus autocomplete="off">
                        <button type="submit" class="btn btn-dark px-4" style="border-radius: 0 15px 15px 0;">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                </form>

                <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var nombre in Model)
                        {
                            <div class="friend-badge">
                                <span>@nombre</span>
                                <form asp-action="RemoveNombreRandom" asp-controller="Statics" method="post" class="m-0 p-0">
                                    <input type="hidden" name="nombre" value="@nombre" />
                                    <button type="submit" class="btn-remove">
                                        <i class="fa-solid fa-x"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted small italic">La lista está vacía...</div>
                    }
                </div>
            </div>

            <div class="slot-display">
                <div class="nombre-ganador @(string.IsNullOrEmpty(ganador) ? "" : "winner-glow")">
                    @(string.IsNullOrEmpty(ganador) ? "???" : ganador)
                </div>
            </div>

            <div class="mb-4">
                @if (Model != null && Model.Count > 1)
                {
                    <form asp-action="SortearRandom" asp-controller="Statics" method="post">
                        <button type="submit" class="btn-spin-master">
                            <i class="fa-solid fa-shuffle me-2"></i> ¡SORTEAR!
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn-spin-master" disabled>
                        Mínimo 2 personas
                    </button>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 border-top pt-4">
                <a asp-controller="Statics" asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                    <i class="fa-solid fa-arrow-left me-1"></i> Dashboard
                </a>

                @if (Model != null && Model.Any())
                {
                    <form asp-action="ResetRandom" asp-controller="Statics" method="post">
                        <button type="submit" class="btn btn-sm text-danger fw-bold border-0 bg-transparent">
                            <i class="fa-solid fa-trash-can me-1"></i> Borrar lista
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>