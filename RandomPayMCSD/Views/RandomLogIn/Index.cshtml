@{
    ViewData["Title"] = "Iniciar sesión";
    string mensaje = ViewData["MENSAJE"] as string;
}

<div class="container d-flex justify-content-center" style="min-height: 80vh; align-items: center;">
    <div class="clean-card" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-4">
            <i class="fa-solid fa-money-bill-transfer fa-3x text-primary"></i>
            <h2 class="fw-bold mt-3 text-primary">RandomPay</h2>
            <p class="text-muted">Comparte gastos fácilmente</p>
        </div>

        @if (!string.IsNullOrEmpty(mensaje))
        {
            <div class="alert alert-danger rounded-4 fw-bold text-center">
                @mensaje
            </div>
        }

        @if (TempData["MENSAJE_EXITO"] != null)
        {
            <div class="alert alert-success rounded-4 fw-bold text-center" style="background-color: #ecfdf5; border-color: #10b981; color: #065f46;">
                <i class="fa-solid fa-check-circle me-1"></i> @TempData["MENSAJE_EXITO"]
            </div>
        }

        <form method="post">
            <div class="mb-4">
                <label class="form-label fw-bold text-muted small">EMAIL</label>
                <input type="email" name="email" class="form-control custom-input" required autofocus />
            </div>
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label fw-bold text-muted small mb-0">CONTRASEÑA</label>
                    <a asp-controller="RandomLogIn" asp-action="ForgotPassword" class="text-primary text-decoration-none small fw-semibold">
                        ¿Has olvidado tu contraseña?
                    </a>
                </div>
                <input type="password" name="password" class="form-control custom-input" required />
            </div>
            <button type="submit" class="btn-primary-custom w-100 py-3">Iniciar sesión</button>
        </form>

        <p class="text-center mt-4 text-muted small fw-semibold">
            ¿No tienes cuenta? <a asp-controller="RandomLogIn" asp-action="Register" class="text-primary text-decoration-none">Regístrate aquí</a>
        </p>
    </div>
</div>