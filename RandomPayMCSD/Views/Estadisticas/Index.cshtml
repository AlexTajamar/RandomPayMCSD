@model RandomPayMCSD.Models.Actividad
@{
    ViewData["Title"] = "Estadísticas - " + Model.NOMBREACTIVIDAD;
    var deudores = (ViewBag.MontosBalance as List<double>)
        .Select((monto, index) => new { Nombre = (ViewBag.NombresBalance as List<string>)[index], Saldo = monto })
        .Where(x => x.Saldo < -0.01)
        .OrderBy(x => x.Saldo)
        .ToList();
}

<style>
    .chart-container {
        position: relative;
        height: 220px;
        width: 100%;
        display: flex;
        justify-content: center;
    }
</style>

<div class="bg-dashboard pt-3">
    <div class="container max-w-6xl">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Actividades" asp-action="Detalle" asp-route-id="@Model.IDACTIVIDAD" class="btn btn-sm btn-light border rounded-pill shadow-sm px-3 fw-bold">
                    <i class="fa-solid fa-arrow-left me-1"></i> Volver
                </a>
                <h4 class="fw-bold mb-0">Análisis Visual</h4>
            </div>
            <div class="badge bg-primary px-3 py-1 rounded-pill shadow-sm fs-6">@Model.MONEDAPRINCIPAL</div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                    <h6 class="fw-bold text-center mb-2"><i class="fa-solid fa-piggy-bank me-2 text-primary"></i>Inversión (Pagado)</h6>
                    <div class="chart-container">
                        <canvas id="chartGastos"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
                    <h6 class="fw-bold text-center mb-2"><i class="fa-solid fa-scale-balanced me-2 text-success"></i>Saldos Actuales</h6>
                    <div class="chart-container mb-3" style="height: 150px;">
                        <canvas id="chartBalances"></canvas>
                    </div>

                    <div class="border-top pt-2">
                        <h6 class="fw-bold text-danger text-uppercase mb-2" style="font-size: 0.8rem;">
                            <i class="fa-solid fa-skull-crossbones me-1"></i> Ranking Deudores
                        </h6>

                        @if (deudores.Any())
                        {
                            <div class="d-flex flex-column gap-1" style="max-height: 130px; overflow-y: auto;">
                                @for (int i = 0; i < deudores.Count; i++)
                                {
                                    var d = deudores[i];
                                    <div class="d-flex justify-content-between align-items-center bg-danger bg-opacity-10 py-1 px-2 rounded-2 border-start border-danger border-3">
                                        <div class="d-flex align-items-center">
                                            <span class="fw-bold me-2 text-danger opacity-50 small">#@(i + 1)</span>
                                            <span class="fw-bold text-dark" style="font-size: 0.9rem;">@d.Nombre</span>
                                            @if (i == 0)
                                            {
                                                <span class="badge bg-danger ms-2" style="font-size:0.6rem">🚩 MÁS RATA</span>
                                            }
                                        </div>
                                        <span class="text-danger fw-bold" style="font-size: 0.9rem;">@d.Saldo.ToString("N2")</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-2">
                                <i class="fa-solid fa-face-grin-stars fs-4 text-success mb-1 d-block"></i>
                                <p class="mb-0 fw-bold text-success small">¡Cuentas al día!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<script>
    Chart.register(ChartDataLabels);

    function formatAbreviado(num) {
        const value = Math.abs(num);
        if (value >= 1.0e+9) return (num / 1.0e+9).toFixed(1) + "B";
        if (value >= 1.0e+6) return (num / 1.0e+6).toFixed(1) + "M";
        if (value >= 1.0e+3) return (num / 1.0e+3).toFixed(1) + "K";
        return num.toFixed(2);
    }

    // TARTA
    const ctxGastos = document.getElementById('chartGastos').getContext('2d');
    new Chart(ctxGastos, {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.Etiquetas)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(ViewBag.ValoresPagados)),
                backgroundColor: ['#2563eb', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'],
                borderWidth: 2, hoverOffset: 10
            }]
        },
        options: {
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
                legend: { position: 'right', labels: { boxWidth: 12, font: { size: 10 } } },
                datalabels: {
                    color: '#fff', font: { weight: 'bold', size: 10 },
                    formatter: (value) => formatAbreviado(value),
                    display: (context) => {
                        let sum = context.dataset.data.reduce((a, b) => a + b, 0);
                        return (context.dataset.data[context.dataIndex] / sum) > 0.05;
                    }
                }
            }
        }
    });

    // BARRAS
    const ctxBalances = document.getElementById('chartBalances').getContext('2d');
    const saldosData = @Html.Raw(Json.Serialize(ViewBag.MontosBalance));

    new Chart(ctxBalances, {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.NombresBalance)),
            datasets: [{
                data: saldosData,
                backgroundColor: saldosData.map(v => v >= 0 ? '#10b981' : '#ef4444'),
                borderRadius: 4
            }]
        },
        options: {
            maintainAspectRatio: false,
            indexAxis: 'y',
            layout: { padding: { right: 40 } },
            plugins: {
                legend: { display: false },
                datalabels: {
                    anchor: 'end', align: 'right', color: '#444',
                    font: { weight: 'bold', size: 10 },
                    formatter: (value) => formatAbreviado(value)
                }
            },
            scales: {
                x: { grid: { display: false }, ticks: { display: false }, border: { display: false } },
                y: { grid: { display: false }, border: { display: false }, ticks: { font: { size: 10 } } }
            }
        }
    });
</script>