@model List<string>
@{
    ViewData["Title"] = "RandomPay - La Ruleta";
    string ganador = ViewBag.Ganador as string;
}

<style>
    .ruleta-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 35px -8px rgba(0,0,0,0.1);
        padding: 3rem 2rem;
        max-width: 650px;
        margin: 0 auto;
        text-align: center;
        border-top: 8px solid #8b5cf6;
    }

    .btn-purple-custom {
        background: #8b5cf6;
        color: white;
        border-radius: 40px;
        padding: 1rem 3rem;
        font-size: 1.25rem;
        font-weight: 700;
        border: none;
        transition: all 0.2s;
        width: 100%;
        margin-top: 1rem;
    }

        .btn-purple-custom:hover {
            transform: scale(1.02);
            background: #6d28d9;
        }

    .nombre-ruleta {
        font-size: 3.5rem;
        font-weight: 800;
        min-height: 100px;
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        word-break: break-all;
    }

    .perdedor-highlight {
        color: #ef4444 !important;
        transform: scale(1.1);
        text-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

    /* Estilos para las etiquetas de nombres */
    .participante-badge {
        font-size: 1rem;
        padding: 0.5rem 1rem;
        border-radius: 30px;
        background-color: #f3f4f6;
        color: #4b5563;
        border: 1px solid #e5e7eb;
        display: inline-flex;
        align-items: center;
        margin: 0.3rem;
    }

    .btn-eliminar-nombre {
        background: none;
        border: none;
        color: #9ca3af;
        margin-left: 0.5rem;
        cursor: pointer;
        padding: 0;
    }

        .btn-eliminar-nombre:hover {
            color: #ef4444;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="ruleta-card">
        <i class="fa-solid fa-dice fa-4x mb-3" style="color: #8b5cf6;"></i>
        <h2 class="fw-bold mb-2" style="color: #8b5cf6;">Sorteo RandomPay</h2>
        <p class="text-muted mb-4">Añade a los amigos y deja que el backend decida quién invita hoy.</p>

        <div class="mb-4">
            <form asp-action="AddNombreRandom" asp-controller="Statics" method="post">
                <div class="input-group input-group-lg">
                    <input type="text" name="nombre" class="form-control rounded-start-4" placeholder="Ej: Álex..." required autofocus>
                    <button type="submit" class="btn btn-outline-secondary rounded-end-4" style="border-color: #ced4da; background-color: #f8f9fa;">
                        <i class="fa-solid fa-plus" style="color: #8b5cf6;"></i> Añadir
                    </button>
                </div>
            </form>

            <div class="mt-3 text-start d-flex flex-wrap justify-content-center">
                @if (Model != null && Model.Any())
                {
                    foreach (var nombre in Model)
                    {
                        <div class="participante-badge">
                            <span class="fw-semibold">@nombre</span>
                            <form asp-action="RemoveNombreRandom" asp-controller="Statics" method="post" class="m-0 p-0 ms-2">
                                <input type="hidden" name="nombre" value="@nombre" />
                                <button type="submit" class="btn-eliminar-nombre" title="Eliminar a @nombre">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>
                        </div>
                    }
                }
                else
                {
                    <span class="text-muted small">No hay participantes todavía.</span>
                }
            </div>
        </div>

        <div class="border rounded-4 bg-light mb-4 py-3">
            @if (!string.IsNullOrEmpty(ganador))
            {
                <div class="nombre-ruleta perdedor-highlight">@ganador</div>
            }
            else
            {
                <div class="nombre-ruleta text-muted">?</div>
            }
        </div>

        @if (Model != null && Model.Count > 1)
        {
            <form asp-action="SortearRandom" asp-controller="Statics" method="post" class="d-inline-block w-100">
                <button type="submit" class="btn-purple-custom">
                    <i class="fa-solid fa-rotate me-2"></i> ¡Girar la Ruleta!
                </button>
            </form>
        }
        else
        {
            <button class="btn-purple-custom" disabled>
                <i class="fa-solid fa-rotate me-2"></i> Mínimo 2 personas
            </button>
        }

        <div class="mt-4 d-flex justify-content-center gap-3">
            <a asp-controller="Statics" asp-action="Index" class="text-decoration-none text-muted">
                <i class="fa-solid fa-arrow-left me-1"></i> Volver al inicio
            </a>

            @if (Model != null && Model.Any())
            {
                <form asp-action="ResetRandom" asp-controller="Statics" method="post">
                    <button type="submit" class="btn btn-link text-danger text-decoration-none p-0">
                        <i class="fa-solid fa-trash me-1"></i> Limpiar todos
                    </button>
                </form>
            }
        </div>
    </div>
</div>