@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="clean-card" style="max-width: 450px; width: 100%;">
        <div class="text-center mb-4">
            <i class="fa-solid fa-unlock-keyhole fa-3x text-primary mb-3"></i>
            <h3 class="fw-bold text-dark">Recuperar Contraseña</h3>
            <p class="text-muted small">Ingresa tu correo y te enviaremos un enlace.</p>
        </div>

        @if (ViewData["MENSAJE_INFO"] != null)
        {
            <div class="alert alert-info rounded-3 fw-bold small text-center">
                <i class="fa-solid fa-envelope-circle-check me-2"></i>@ViewData["MENSAJE_INFO"]
            </div>
        }
        @if (ViewData["MENSAJE_ERROR"] != null)
        {
            <div class="alert alert-danger rounded-3 fw-bold small text-center">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@ViewData["MENSAJE_ERROR"]
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">TU CORREO ELECTRÓNICO</label>
                <input type="email" name="email" class="form-control custom-input" required autofocus />
            </div>
            <button type="submit" class="btn-primary-custom w-100 py-3 mb-3">
                Enviar enlace de recuperación
            </button>
            <div class="text-center">
                <a asp-action="Index" class="text-muted text-decoration-none small fw-bold">Volver al login</a>
            </div>
        </form>
    </div>
</div>