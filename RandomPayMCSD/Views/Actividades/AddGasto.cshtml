@model RandomPayMCSD.Models.Gasto
@{
    bool esEdicion = Model.IDGASTO > 0;
    ViewData["Title"] = esEdicion ? "Editar Gasto" : "Añadir Gasto";

    var participantes = ViewBag.Participantes as List<RandomPayMCSD.Models.Participante>;
    var divisas = ViewBag.Divisas as List<RandomPayMCSD.Models.Divisa>;
    var repartosExistentes = ViewBag.Repartos as List<RandomPayMCSD.Models.RepartoGasto>;

    var divisasJson = System.Text.Json.JsonSerializer.Serialize(divisas?.Select(d => new { d.Codigo, d.Tasa }));
}

<style>
    .bg-dashboard {
        background-color: #f8fafc;
        min-height: 100vh;
    }

    .clean-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        padding: 1.5rem;
        border: 1px solid #f1f5f9;
    }

    .participant-row {
        background: #f8fafc;
        border-radius: 10px;
        padding: 10px 15px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #e2e8f0;
    }

    .amount-input {
        width: 100px;
        text-align: right;
        border: 2px solid transparent;
        background: transparent;
        font-weight: bold;
        font-size: 1rem;
        color: #1e293b;
        padding: 3px;
        border-radius: 6px;
    }

        .amount-input:focus {
            border-bottom: 2px solid #3b82f6;
            outline: none;
            background: white;
        }

        .amount-input.manual-edit {
            color: #3b82f6;
        }

    .btn-primary-custom {
        background: #2563eb;
        color: white;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        border: none;
    }
</style>

<div class="bg-dashboard pt-3">
    <div class="container max-w-4xl">
        <div class="clean-card">

            <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
                <div class="p-2 rounded-circle bg-primary bg-opacity-10 me-3">
                    <i class="fa-solid @(esEdicion ? "fa-pen" : "fa-receipt") fs-4 text-primary"></i>
                </div>
                <h4 class="fw-bold mb-0 text-dark">@(esEdicion ? "Editar Gasto" : "Añadir Gasto")</h4>
            </div>

            <form asp-action="@(esEdicion ? "EditGasto" : "AddGasto")" method="post">
                <input type="hidden" asp-for="IDACTIVIDAD" />
                @if (esEdicion)
                {
                    <input type="hidden" asp-for="IDGASTO" />
                    <input type="hidden" asp-for="FECHA" />
 }

                @if (ViewBag.IdItemCompra != null)
                {
                    <input type="hidden" name="idItemCompra" value="@ViewBag.IdItemCompra" />
                    <div class="alert alert-success fw-bold rounded-3 mb-3 py-2 d-flex align-items-center" style="background-color: #ecfdf5; border: 1px solid #10b981; color: #065f46;">
                        <i class="fa-solid fa-cart-circle-check fs-4 me-2 text-success"></i>
                        <div><h6 class="fw-bold mb-0" style="font-size:0.9rem">Confirmando compra</h6></div>
                    </div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-md-12">
                        <label class="form-label small text-muted fw-bold mb-1">CONCEPTO</label>
                        <input type="text" asp-for="CONCEPTO" class="form-control custom-input py-1" placeholder="Ej: Cena..." required>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label small text-muted fw-bold mb-1">TOTAL</label>
                        <input type="number" step="0.01" name="importeString" id="totalInput" class="form-control custom-input fs-5 fw-bold text-primary py-1"
                               value="@(Model.IMPORTE > 0 ? Model.IMPORTE.ToString(System.Globalization.CultureInfo.InvariantCulture) : "")" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted fw-bold mb-1">MONEDA</label>
                        <select name="divisaSeleccionada" id="divisaSelect" class="form-select custom-input py-1">
                            @if (divisas != null)
                            {
                                @foreach (var d in divisas)
                                {
                                    <option value="@d.Codigo" selected="@(d.Codigo == "EUR")">@d.Codigo</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted fw-bold mb-1">PAGADOR</label>
                        <select asp-for="IDPAGADOR" class="form-select custom-input py-1" required>
                            @if (participantes != null)
                            {
                                @foreach (var p in participantes)
                                {
                                    <option value="@p.IDPARTICIPANTE">@p.NOMBREPARTICIPANTE</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div id="conversionInfo" class="alert alert-info py-1 px-3 mb-3 small" style="display:none; font-weight: 500;">
                    <i class="fa-solid fa-arrow-right-arrow-left me-2"></i> Eqv. <span id="conversionResult" class="fw-bold">0</span> EUR
                </div>

                <div class="p-3 bg-light rounded-3 border">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold text-dark mb-0">División</h6>
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" id="btnEqual">
                            <i class="fa-solid fa-scale-balanced me-1"></i> Partes Iguales
                        </button>
                    </div>

                    <div id="participantsList" style="max-height: 250px; overflow-y: auto;">
                        @if (participantes != null)
                        {
                            for (int i = 0; i < participantes.Count; i++)
                            {
                                var p = participantes[i];
                                var rep = repartosExistentes?.FirstOrDefault(r => r.IdParticipante == p.IDPARTICIPANTE);
                                double valor = rep?.Cantidad ?? 0;
                                bool marcado = esEdicion ? (rep != null) : true;

                                <div class="participant-row py-1">
                                    <div class="d-flex align-items-center">
                                        <input type="hidden" name="idsParticipantes" value="@p.IDPARTICIPANTE" />
                                        <div class="form-check form-switch me-2 mb-0">
                                            <input class="form-check-input check-participante" type="checkbox" role="switch" @(marcado ? "checked" : "") style="cursor: pointer;">
                                        </div>
                                        <span class="fw-semibold text-dark" style="font-size: 0.95rem;">@p.NOMBREPARTICIPANTE</span>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <input type="number" step="0.01" name="cantidadesAsignadas" class="amount-input participante-monto" value="@valor.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        <span class="ms-1 text-muted small fw-bold divisa-label">EUR</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="Detalle" asp-route-id="@Model.IDACTIVIDAD" class="btn btn-sm btn-light border py-2 px-4 fw-bold">Cancelar</a>
                    <button type="submit" class="btn btn-sm btn-primary-custom py-2 px-4 fw-bold shadow-sm">
                        @(esEdicion ? "Actualizar" : "Guardar") <i class="fa-solid fa-check ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* Mismo JS que ya tenías, no hace falta cambiar la lógica *@
    <script>
        const tasasDB = @Html.Raw(divisasJson ?? "[]");
        const totalInput = document.getElementById('totalInput');
        const divisaSelect = document.getElementById('divisaSelect');
        const btnEqual = document.getElementById('btnEqual');
        const montos = document.querySelectorAll('.participante-monto');
        const checks = document.querySelectorAll('.check-participante');
        const labelsMoneda = document.querySelectorAll('.divisa-label');

        let manualEdits = new Set();

        function actualizarEstadoFila(index, isChecked) {
            const row = montos[index].closest('.participant-row');
            if (isChecked) {
                row.style.opacity = '1'; montos[index].readOnly = false;
            } else {
                row.style.opacity = '0.5'; montos[index].readOnly = true; montos[index].value = "0.00"; montos[index].classList.remove('manual-edit');
            }
        }

        function actualizarDivisas() {
            const moneda = divisaSelect.value;
            labelsMoneda.forEach(l => l.innerText = moneda);
            const importe = parseFloat(totalInput.value) || 0;
            const infoDiv = document.getElementById('conversionInfo');
            if(moneda !== 'EUR' && importe > 0) {
                const tasa = tasasDB.find(t => t.Codigo === moneda)?.Tasa || 1;
                document.getElementById('conversionResult').innerText = (importe / tasa).toFixed(2);
                infoDiv.style.display = 'block';
            } else { infoDiv.style.display = 'none'; }
        }

        function recalcularSobrante() {
            const total = parseFloat(totalInput.value) || 0;
            let sumManual = 0; let autoIndexes = [];
            checks.forEach((check, index) => {
                actualizarEstadoFila(index, check.checked);
                if (check.checked) {
                    if (manualEdits.has(index)) sumManual += parseFloat(montos[index].value) || 0;
                    else autoIndexes.push(index);
                }
            });
            const restante = Math.max(0, total - sumManual);
            if (autoIndexes.length > 0) {
                const porPersona = restante / autoIndexes.length;
                autoIndexes.forEach(idx => { montos[idx].value = porPersona.toFixed(2); montos[idx].classList.remove('manual-edit'); });
            }
        }

        function repartirEquitativamente() {
            manualEdits.clear();
            const total = parseFloat(totalInput.value) || 0;
            const activos = Array.from(checks).filter(c => c.checked);
            if (activos.length > 0) {
                const porPersona = total / activos.length;
                checks.forEach((check, index) => {
                    actualizarEstadoFila(index, check.checked);
                    if (check.checked) { montos[index].value = porPersona.toFixed(2); montos[index].classList.remove('manual-edit'); }
                });
            } else { checks.forEach((check, index) => actualizarEstadoFila(index, false)); }
        }

        totalInput.addEventListener('input', () => { actualizarDivisas(); if(manualEdits.size === 0) repartirEquitativamente(); else recalcularSobrante(); });
        divisaSelect.addEventListener('change', actualizarDivisas);

        montos.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (checks[index].checked) { manualEdits.add(index); input.classList.add('manual-edit'); recalcularSobrante(); }
            });
        });

        checks.forEach((check, index) => {
            check.addEventListener('change', () => {
                if (!check.checked) manualEdits.delete(index);
                if(manualEdits.size === 0) repartirEquitativamente(); else recalcularSobrante();
            });
        });

        btnEqual.addEventListener('click', () => { checks.forEach(c => c.checked = true); repartirEquitativamente(); });

        actualizarDivisas();
        checks.forEach((check, index) => actualizarEstadoFila(index, check.checked));

        @if (!esEdicion)
        {
            <text>repartirEquitativamente();</text>
        }
    </script>
}