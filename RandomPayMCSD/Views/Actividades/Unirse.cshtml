@{
    ViewData["Title"] = "Unirse con Código";
}
<div class="container mt-5 d-flex justify-content-center">
    <div class="clean-card text-center" style="max-width: 450px; width: 100%;">
        <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-circle d-inline-block mb-4">
            <i class="fa-solid fa-key fa-3x"></i>
        </div>
        <h3 class="fw-bold text-dark mb-2">Unirse a actividad</h3>
        <p class="text-muted mb-4">Pídele al creador el código secreto de 8 letras.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger fw-bold rounded-3">@ViewBag.Error</div>
        }

        <form asp-action="Unirse" method="post">
            <input type="text" name="codigo" class="form-control custom-input text-center fs-4 fw-bold text-uppercase mb-4" placeholder="EJ: CUMPLE26" style="letter-spacing: 2px;" required autofocus autocomplete="off">
            <button type="submit" class="btn-primary-custom w-100 py-3 mb-2 text-dark" style="background-color: #fbbf24;">
                Buscar actividad <i class="fa-solid fa-magnifying-glass ms-2"></i>
            </button>
            <a asp-controller="Statics" asp-action="Index" class="btn btn-light border w-100 py-3 fw-bold rounded-3">Cancelar</a>
        </form>
    </div>
</div>