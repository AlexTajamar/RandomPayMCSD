@using RandomPayMCSD.Models
@using RandomPayMCSD.Extensions
@{
    Usuario currentUser = Context.Session.getObject<Usuario>("USUARIO_LOGUEADO");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RandomPay</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* === ESTILOS DEL LAYOUT BLINDADO === */
        html, body {
            height: 100%;
            background-color: #f8fafc; /* Evita el corte blanco al hacer overscroll */
        }

        body {
            display: flex;
            flex-direction: column;
            font-family: 'Inter', sans-serif;
            color: #1f2937;
            margin: 0;
        }

        /* Contenedor que empuja el footer hacia abajo */
        .main-content {
            flex: 1 0 auto;
        }

        /* Footer anclado abajo */
        .footer-custom {
            flex-shrink: 0;
            background-color: white;
            border-top: 1px solid #e5e7eb;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.6rem;
        }

        .navbar-dark {
            background: linear-gradient(145deg, #2563eb, #1d4ed8) !important;
            box-shadow: 0 4px 20px rgba(37, 99, 235, 0.2);
        }

        .btn-outline-light {
            border-width: 2px;
            border-radius: 30px;
            font-weight: 600;
        }

        /* === CLASES GLOBALES UNIFICADAS === */
        .clean-card {
            background: white;
            border-radius: 20px;
            padding: 3rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.04);
            border: 1px solid #e5e7eb;
        }

        .custom-input {
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            padding: 0.8rem 1rem;
            transition: all 0.2s;
            font-weight: 500;
            background-color: #fcfcfd;
        }

            .custom-input:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 4px rgba(59,130,246,0.1);
                background-color: white;
                outline: none;
            }

        .btn-primary-custom {
            background: #2563eb;
            color: white;
            border-radius: 12px;
            padding: 0.8rem 1.5rem;
            font-weight: 600;
            border: none;
            transition: all 0.2s;
        }

            .btn-primary-custom:hover {
                background: #1d4ed8;
                transform: translateY(-2px);
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Statics" asp-action="Index">
                    <i class="fa-solid fa-money-bill-transfer me-2"></i>RandomPay
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Statics" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link text-white opacity-75" asp-controller="Statics" asp-action="Privacy">Privacidad</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (currentUser != null)
                        {
                            <li class="nav-item d-flex align-items-center me-3 text-white">Hola, <strong class="ms-1">@currentUser.NOMBRE</strong></li>
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm px-3" asp-controller="RandomLogIn" asp-action="LogOut">Salir</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="btn btn-light btn-sm fw-bold px-3" style="color: #2563eb; border-radius: 30px;" asp-controller="RandomLogIn" asp-action="Index">Iniciar Sesión</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content">
        <div class="container pb-4">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer-custom py-4">
        <div class="container text-center text-muted fw-bold small">
            &copy; 2026 - RandomPay
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>